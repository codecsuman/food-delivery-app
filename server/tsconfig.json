{
                "compilerOptions": {
                                "target": "ES2020",
                                "module": "NodeNext",
                                "moduleResolution": "NodeNext",
                                "esModuleInterop": true,
                                "strict": true,
                                "skipLibCheck": true,
                                "forceConsistentCasingInFileNames": true,
                                "outDir": "./dist",
                                "rootDir": ".",
                                "resolveJsonModule": true,
                                "declaration": false,
                                "declarationMap": false,
                                "sourceMap": false
                },
                "include": [
                                "*.ts",
                                "controller/**/*.ts",
                                "db/**/*.ts",
                                "mailtrap/**/*.ts",
                                "middlewares/**/*.ts",
                                "models/**/*.ts",
                                "routes/**/*.ts",
                                "utils/**/*.ts"
                ],
                "exclude": [
                                "node_modules",
                                "dist"
                ]
}